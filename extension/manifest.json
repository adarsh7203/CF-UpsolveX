{
  "manifest_version": 3,
  "name": "CF UpsolveX Companion",
  "version": "1.0.0",
  "description": "Your Codeforces productivity companion. See your priority upsolve queue directly on Codeforces.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "*://*.codeforces.com/*",
    "https://cf-upsolvex.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.codeforces.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
